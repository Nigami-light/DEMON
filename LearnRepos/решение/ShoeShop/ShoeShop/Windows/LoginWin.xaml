<Window
    x:Class="ShoeShop.Windows.LoginWin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ShoeShop.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Авторизация"
    Width="350"
    Height="400"
    Icon="/Images/Icon.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

        <Image Width="50" Source="/Images/Icon.png" />

        <TextBlock FontWeight="Bold" Text="Email" />

        <TextBox x:Name="LoginTB" />

        <TextBlock FontWeight="Bold" Text="Пароль" />

        <PasswordBox x:Name="PasswTB" />


        <Button
            x:Name="LoginBtn"
            Margin="10"
            Click="LoginBtn_Click"
            Content="Войти"
            Cursor="Hand"
            Style="{StaticResource GreenBtn}" />
        <TextBlock
            x:Name="GuestTb"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Cursor="Hand"
            FontWeight="Bold"
            MouseLeftButtonUp="GuestTb_MouseLeftButtonUp"
            Text="Посмотреть товары" />

    </StackPanel>
</Window>
