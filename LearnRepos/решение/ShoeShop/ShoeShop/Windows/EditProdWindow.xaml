<Window
    x:Class="ShoeShop.Windows.EditProdWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Редактирование товара"
    Width="860"
    Height="770"
    Icon="/Images/Icon.ico"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">


    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Id" />
                <TextBox
                    x:Name="IdTB"
                    Margin="0,0,0,10"
                    Background="#EEE"
                    IsReadOnly="True" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Наименование" />
                <ComboBox
                    x:Name="ProdNameCB"
                    Margin="0,0,0,10"
                    DisplayMemberPath="ProdName1"
                    SelectedValuePath="IdProdName" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Категория" />
                <ComboBox
                    x:Name="CategoryCB"
                    Margin="0,0,0,10"
                    DisplayMemberPath="CatName"
                    SelectedValuePath="IdCat" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Описание" />
                <TextBox
                    x:Name="DescTB"
                    Height="100"
                    Margin="0,0,0,10"
                    AcceptsReturn="True"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Производитель" />
                <ComboBox
                    x:Name="ManufCB"
                    Margin="0,0,0,10"
                    DisplayMemberPath="ManufName"
                    SelectedValuePath="IdManuf" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Поставщик" />
                <ComboBox
                    x:Name="SupplierCB"
                    Margin="0,0,0,10"
                    DisplayMemberPath="SupName"
                    SelectedValuePath="IdSup" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Цена" />
                <TextBox x:Name="PriceTB" Margin="0,0,0,10" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Единица измерения" />
                <TextBox x:Name="CouTB" Margin="0,0,0,10" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Количество на складе" />
                <TextBox x:Name="CountTB" Margin="0,0,0,10" />

                <TextBlock
                    Margin="0,5"
                    FontSize="16"
                    Text="Скидка (%)" />
                <TextBox x:Name="SaleTB" Margin="0,0,0,10" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
            <Border
                Width="300"
                Height="200"
                Margin="0,0,0,10"
                BorderBrush="Gray"
                BorderThickness="1">
                <Image x:Name="ProdImg" Stretch="Uniform" />
            </Border>

            <Button
                x:Name="ChangeImageBtn"
                Width="200"
                Margin="0,0,0,20"
                Click="ChangeImageBtn_Click"
                Content="Изменить изображение"
                Cursor="Hand"
                Style="{StaticResource GreenBtn}" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Margin="0,20,0,0"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                x:Name="SaveBtn"
                Width="100"
                Margin="5"
                Click="SaveBtn_Click"
                Content="Сохранить"
                Cursor="Hand"
                Style="{StaticResource GreenBtn}" />
            <Button
                x:Name="CancelBtn"
                Width="100"
                Margin="5"
                Click="CancelBtn_Click"
                Content="Отмена"
                Cursor="Hand"
                Style="{StaticResource GreenBtn}" />
        </StackPanel>
    </Grid>
</Window>
